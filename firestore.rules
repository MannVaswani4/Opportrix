rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
      allow delete: if false; // Soft deletes handled by Cloud Functions
    }

    match /aggregatedPosts/{postId} {
      // Anyone authenticated can read aggregated posts
      allow read: if isAuthenticated();
      // Only backend admin can write aggregated posts
      allow write: if false; 
    }

    match /nativePosts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        // Allow anyone to update likes/comment counts (in production use transactions/cloud functions to secure this)
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likes', 'commentCount'])
      );
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /nativePostComments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /commentsHistory/{historyId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Immutable log
    }

    match /shortlists/{userId}/candidates/{candidateId} {
      allow read, write: if isOwner(userId);
    }
  }
}
